{
    "name": "migrane-tracker-dashboard",
    "private": true,
    "version": "1.0.0",
    "type": "module",
    "scripts": {
        "dev": "vite",
        "build": "vite build",
        "lint": "eslint . --fix",
        "preview": "vite preview",
        "knip": "knip -c ./knip.json",
        "format": "prettier --write \"src/**/*.{js,jsx,ts,tsx,json,css,scss,md}\"",
        "prepare": "husky",
        "update": "ncu -i --format=group",
        "typecheck": "tsc --noEmit"
    },
    "dependencies": {
        "@supabase/supabase-js": "^2.75.0",
        "appwrite": "^16.1.0",
        "chart.js": "^4.5.0",
        "lucide-react": "^0.545.0",
        "luxon": "^3.7.2",
        "react": "^18.3.1",
        "react-calendar-heatmap": "^1.10.0",
        "react-chartjs-2": "^5.3.0",
        "react-dom": "^18.3.1",
        "react-router-dom": "^6.22.3"
    },
    "devDependencies": {
        "@eslint/js": "^9.37.0",
        "@types/luxon": "^3.7.1",
        "@types/react": "^18.3.5",
        "@types/react-calendar-heatmap": "^1.9.0",
        "@types/react-dom": "^18.3.0",
        "@vitejs/plugin-react": "^4.3.1",
        "autoprefixer": "^10.4.21",
        "eslint": "^9.37.0",
        "eslint-plugin-react-hooks": "^5.1.0-rc.0",
        "eslint-plugin-react-refresh": "^0.4.23",
        "globals": "^15.9.0",
        "husky": "^9.1.7",
        "knip": "^5.64.3",
        "lint-staged": "^15.2.2",
        "npm-check-updates": "^19.0.0",
        "postcss": "^8.5.6",
        "prettier": "^3.6.2",
        "tailwindcss": "^3.4.1",
        "typescript": "^5.9.3",
        "typescript-eslint": "^8.46.0",
        "vite": "^5.4.2"
    },
    "lint-staged": {
        "*.{js,jsx,ts,tsx}": [
            "prettier --write",
            "eslint --fix"
        ],
        "*.{json,css,scss,md}": [
            "prettier --write"
        ]
    }
}
